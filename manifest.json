{
  "manifest_version": 3,
  "name": "Glowing Monocle",
  "version": "0.2.1",
  "description": "A Chrome extension to analyse images in the browser",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Glowing Monocle",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "permissions": [
    "contextMenus",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:11434/*",
    "http://*/*",
    "https://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content.html",
        "content.css",
        "vendor/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}